# Flask Configuration
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# Database
DATABASE_URL=mysql+pymysql://root:password@localhost/gcash_payments

# PayMongo API Keys (get from https://dashboard.paymongo.com)
PAYMONGO_SECRET_KEY=sk_test_xxxxxxxxxxxx
PAYMONGO_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
PAYMONGO_WEBHOOK_SECRET=whsk_xxxxxxxxxxxx

# File Uploads
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=5242880

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5500
